# 이 파일을 복사해 devices.secret.yaml 로 저장한 뒤 실제 IP·암호를 넣으세요.
# devices.secret.yaml 은 .gitignore 에 포함되어 커밋되지 않습니다.
#
# 대시보드「설정」또는 user_settings.json 에서 inventory_path 를
# devices.secret.yaml 로 지정해 사용할 수 있습니다.

devices:
  - ip: "192.168.0.10"
    vendor: "cisco"
    snmp:
      v3_username: "여기에_사용자"
      v3_auth_key: "여기에_인증키"
      v3_auth_protocol: "sha"
      v3_priv_key: "여기에_암호키"
      v3_priv_protocol: "aes"
      community: "public"
    ssh:
      username: "admin"
      password: "여기에_비밀번호"
